# Copy this to .env and fill in your key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# Encrypts message content + memory digests at rest, so the database on its own
# can't be read. Leave unset and everything stores as plaintext, as before.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# KEEP A COPY SOMEWHERE SAFE — lose it and every stored conversation is unreadable.
FIELD_ENCRYPTION_KEY=
